<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Calculateur IMC"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#222222"
            android:layout_marginBottom="25dp" />

        <EditText
            android:id="@+id/poidsInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Poids en kg"
            android:inputType="numberDecimal"
            android:padding="14dp"
            android:background="#FFFFFF" />

        <EditText
            android:id="@+id/tailleInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Taille en m"
            android:inputType="numberDecimal"
            android:padding="14dp"
            android:background="#FFFFFF"
            android:layout_marginTop="15dp" />

        <Button
            android:id="@+id/calculerButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Calculer IMC"
            android:layout_marginTop="20dp" />

        <TextView
            android:id="@+id/resultatText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Résultat"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#000000"
            android:layout_marginTop="25dp" />

        <TextView
            android:id="@+id/categorieText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:padding="16dp"
            android:layout_marginTop="15dp" />

    </LinearLayout>

</ScrollView>